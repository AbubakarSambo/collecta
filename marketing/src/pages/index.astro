---
import Layout from '../layouts/Layout.astro'

const APP_URL = 'https://app.collecta.services'

const features = [
  {
    icon: '🏷️',
    title: 'Branded Payment Page',
    description: 'Your community gets a branded URL — collecta.services/n/yourname. Members pay directly without confusion.',
  },
  {
    icon: '💰',
    title: 'Two Fee Types',
    description: 'ASSIGNED fees auto-generate monthly charges per member. OPEN fees let members pick and pay on demand.',
  },
  {
    icon: '🔔',
    title: 'Auto Reminders',
    description: 'Automated WhatsApp, SMS, and email reminders go out to non-payers — no more manual chasing.',
  },
  {
    icon: '📊',
    title: 'Compliance Tracking',
    description: 'See exactly who is current and who is overdue. Export compliance reports in one click.',
  },
]

const steps = [
  {
    number: '01',
    title: 'Create your network',
    description: 'Sign up, give your community a name and branded slug. Takes 2 minutes.',
  },
  {
    number: '02',
    title: 'Add members and fees',
    description: 'Import members via CSV or add manually. Create fees and assign them — system generates charges automatically.',
  },
  {
    number: '03',
    title: 'Collect and track',
    description: 'Members pay via Paystack on your branded page. You see real-time compliance and payment status.',
  },
]
---

<Layout title="Collect Community Fees Without the Chaos">
  <!-- NAV -->
  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
    <div class="mx-auto max-w-6xl px-4 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-green-600 text-white font-bold text-sm">
          C
        </div>
        <span class="text-lg font-bold text-gray-900">Collecta</span>
      </div>
      <div class="flex items-center gap-4">
        <a href={`${APP_URL}/login`} class="text-sm text-gray-600 hover:text-gray-900">Sign in</a>
        <a
          href={`${APP_URL}/register`}
          class="rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700 transition-colors"
        >
          Get started free
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="bg-gradient-to-b from-green-50 to-white py-20 px-4">
    <div class="mx-auto max-w-4xl text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-green-100 px-4 py-1.5 text-sm font-medium text-green-800">
        🇳🇬 Nigeria-first • Paystack-powered
      </div>
      <h1 class="text-5xl font-bold text-gray-900 leading-tight">
        The smartest way to collect fees<br />in your community
      </h1>
      <p class="mt-6 text-xl text-gray-600 max-w-2xl mx-auto">
        Estate managers, coop admins, gym owners — collect dues from members without the chaos.
        Automated charges, branded payment pages, and zero chasing.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={`${APP_URL}/register`}
          class="rounded-xl bg-green-600 px-8 py-4 text-lg font-semibold text-white hover:bg-green-700 transition-colors shadow-lg shadow-green-200"
        >
          Create Your Network Free
        </a>
        <a
          href="#how-it-works"
          class="rounded-xl border-2 border-gray-200 px-8 py-4 text-lg font-semibold text-gray-700 hover:border-gray-300 transition-colors"
        >
          See How It Works
        </a>
      </div>
      <p class="mt-4 text-sm text-gray-400">No credit card required. Free to start.</p>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="py-8 bg-white border-y border-gray-100">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <p class="text-gray-500 text-sm font-medium tracking-wide uppercase">
        Trusted by 500+ community admins across Nigeria
      </p>
      <div class="mt-4 flex flex-wrap justify-center gap-6 text-gray-400 text-sm">
        <span>Estate Managers</span>
        <span>•</span>
        <span>Cooperative Societies</span>
        <span>•</span>
        <span>Sports Clubs</span>
        <span>•</span>
        <span>Alumni Associations</span>
        <span>•</span>
        <span>Religious Groups</span>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-20 px-4 bg-white">
    <div class="mx-auto max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">Everything you need to collect fees</h2>
        <p class="mt-3 text-gray-500 max-w-xl mx-auto">
          Purpose-built for African community administrators who are tired of chasing payments on WhatsApp.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {features.map(feature => (
          <div class="rounded-2xl border border-gray-100 bg-gray-50 p-6 hover:border-green-200 hover:bg-green-50 transition-colors">
            <div class="text-3xl mb-3">{feature.icon}</div>
            <h3 class="text-lg font-semibold text-gray-900">{feature.title}</h3>
            <p class="mt-2 text-sm text-gray-500 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="py-20 px-4 bg-gray-50">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">Up and running in minutes</h2>
      </div>
      <div class="space-y-8">
        {steps.map(step => (
          <div class="flex items-start gap-6">
            <div class="flex-shrink-0 flex h-12 w-12 items-center justify-center rounded-full bg-green-600 text-white font-bold text-lg">
              {step.number}
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900">{step.title}</h3>
              <p class="mt-1 text-gray-500">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="py-20 px-4 bg-white">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold text-gray-900">Simple, honest pricing</h2>
      <p class="mt-3 text-gray-500">Start free. Upgrade as you grow.</p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 max-w-2xl mx-auto">
        <div class="rounded-2xl border-2 border-gray-200 p-8 text-left">
          <h3 class="text-xl font-bold text-gray-900">Starter</h3>
          <p class="mt-2 text-4xl font-bold text-gray-900">Free</p>
          <p class="mt-1 text-sm text-gray-500">Forever</p>
          <ul class="mt-6 space-y-2 text-sm text-gray-600">
            <li>✓ Up to 50 members</li>
            <li>✓ Paystack payments</li>
            <li>✓ Basic reminders</li>
            <li>✓ Branded portal</li>
          </ul>
          <a href={`${APP_URL}/register`} class="mt-6 block text-center rounded-lg border-2 border-green-600 px-4 py-2.5 text-sm font-semibold text-green-700 hover:bg-green-50 transition-colors">
            Get started
          </a>
        </div>

        <div class="rounded-2xl border-2 border-green-600 bg-green-50 p-8 text-left relative">
          <div class="absolute top-4 right-4 rounded-full bg-green-600 px-2.5 py-0.5 text-xs font-semibold text-white">Popular</div>
          <h3 class="text-xl font-bold text-gray-900">Pro</h3>
          <p class="mt-2 text-4xl font-bold text-gray-900">₦5,000<span class="text-lg text-gray-500 font-normal">/mo</span></p>
          <p class="mt-1 text-sm text-gray-500">Per network</p>
          <ul class="mt-6 space-y-2 text-sm text-gray-600">
            <li>✓ Unlimited members</li>
            <li>✓ WhatsApp + SMS reminders</li>
            <li>✓ PDF & Excel exports</li>
            <li>✓ Penalty automation</li>
            <li>✓ Priority support</li>
          </ul>
          <a href={`${APP_URL}/register`} class="mt-6 block text-center rounded-lg bg-green-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-green-700 transition-colors">
            Start free trial
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 bg-green-600">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-white">Ready to end payment chaos?</h2>
      <p class="mt-3 text-green-100">
        Join 500+ community admins already using Collecta to collect fees on time, every time.
      </p>
      <a
        href={`${APP_URL}/register`}
        class="mt-8 inline-block rounded-xl bg-white px-10 py-4 text-lg font-bold text-green-700 hover:bg-green-50 transition-colors shadow-lg"
      >
        Create Your Network Free →
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 py-12 px-4">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div class="flex items-center gap-2">
          <div class="flex h-7 w-7 items-center justify-center rounded-md bg-green-600 text-white font-bold text-sm">C</div>
          <span class="text-white font-semibold">Collecta</span>
        </div>
        <div class="flex gap-6 text-sm text-gray-400">
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="/terms" class="hover:text-white">Terms</a>
          <a href="mailto:hello@collecta.services" class="hover:text-white">Contact</a>
        </div>
      </div>
      <p class="mt-6 text-sm text-gray-500">
        © {new Date().getFullYear()} Collecta. Built for African communities.
      </p>
    </div>
  </footer>
</Layout>
