---
import Layout from '../layouts/Layout.astro'

const APP_URL = 'https://app.collecta.services'
const REGISTER = `${APP_URL}/register`

const proofItems = [
  "Paystack (Nigeria) · M-Pesa via Africa's Talking (Kenya)",
  'NGN & KES supported',
  'Card, bank transfer, USSD & mobile money',
  "SMS via Africa's Talking",
  'Automated reminders & penalties',
  'Automatic payment tracking',
]

const steps = [
  { n: '01', title: 'Create your network', body: 'Set up your estate, group, or organisation. Add members one by one or upload a CSV list. Every network gets its own payment portal link instantly.' },
  { n: '02', title: 'Define your fees', body: 'Set assigned fees (everyone owes a fixed amount) or open fees (members choose from options you define). Set due dates, grace periods, and penalty rules.' },
  { n: '03', title: 'Automate collection', body: 'Set your reminder rules once and Collecta handles the rest — SMS and email reminders go out automatically, late fees apply after grace periods, and you are notified the moment a payment lands.' },
  { n: '04', title: 'Track and report', body: 'Real-time dashboard shows collection totals, recent payments, and collection rate. Every transaction is recorded with a full audit trail.' },
  { n: '05', title: 'Collect and grow', body: "Watch your collection rate climb. Share your portal link on WhatsApp, embed it in your website, or let Collecta's reminders do the work. Your members pay. Your account receives." },
]

const features = [
  { icon: '📨', title: 'Automated reminders', body: 'Scheduled SMS and email reminders fire automatically before and after due dates. No manual WhatsApp messages. No awkward conversations.' },
  { icon: '⚖️', title: 'Penalties & late fees', body: "Set a grace period and a penalty percentage. Collecta applies late fees automatically and updates the member's balance without any admin action." },
  { icon: '💳', title: 'Two fee types', body: 'Assigned fees (everyone owes a set amount) and open fees (members choose from options you define — event access, service tiers, top-up amounts).' },
  { icon: '🔗', title: 'Embed anywhere', body: 'Drop your payment portal into your own website with one line of code. Members pay without leaving your site.' },
  { icon: '🏘️', title: 'Networks & clusters', body: 'Manage multiple estates or groups from one dashboard. Ideal for property management companies running several developments simultaneously.' },
  { icon: '🏦', title: 'Direct payout account', body: "Attach your bank account and collected fees flow directly to you via Paystack — minus Collecta's transparent platform fee. Settlement is next business day." },
  { icon: '📊', title: 'Reports & audit trails', body: "Real-time view of who has paid and who hasn't, collection totals, and payment history. Full audit trail of every transaction stored automatically." },
  { icon: '🚫', title: 'Access control', body: 'Restrict access for persistently overdue members as a prompt to pay. Once cleared, the admin reinstates access — a straightforward lever for compliance.' },
]

const whoUses = [
  { icon: '🏘️', title: 'Residential estates', body: 'Service charges, facility fees, security levies. Built for the estate manager tired of chasing 200 residents on WhatsApp.' },
  { icon: '🏢', title: 'Property managers', body: 'Manage multiple developments from one dashboard. Each estate gets its own portal, fee structure, and payment history.' },
  { icon: '🤝', title: 'Cooperatives & associations', body: 'Ajo groups, savings cooperatives, professional associations, alumni networks. Contributions tracked and enforced transparently.' },
  { icon: '🎓', title: 'Schools', body: 'Term fees, activity levies, uniform charges. Parents pay via card, bank transfer, or USSD. Finance teams spend less time on follow-ups.' },
  { icon: '💪', title: 'Gyms & clubs', body: 'Monthly membership fees and recurring subscriptions. Members pay through your portal and get reminded automatically at renewal.' },
  { icon: '💼', title: 'Debt collectors', body: 'Upload a list of people who owe you — name, phone, amount, due date. Collecta sends reminders and they pay through the portal.' },
  { icon: '🗑️', title: 'Service providers', body: 'Waste collection, security services, facility management. Bill clients professionally and track compliance without the paperwork.' },
]

const pricingFeatures = [
  'Payment portal — share a link or embed in your site',
  'Assigned & open payment types',
  'Automated SMS & email reminders',
  '50 free SMS credits when you go live',
  'SMS credits top up with every payment collected',
  'CSV import for large member lists',
  'Dashboard, payment tracking & audit trail',
  'Penalties, access control & blast messaging',
  'Multiple networks from one account',
]
---

<Layout title="Collect Smarter">
  <!-- NAV -->
  <nav class="sticky top-0 z-[100] border-b border-line bg-white/90 backdrop-blur-md">
    <div class="mx-auto flex h-16 max-w-[1100px] items-center justify-between px-6">
      <a href="/" class="flex items-center gap-2.5">
        <div class="flex h-9 w-9 items-center justify-center rounded-[9px] bg-black">
          <span class="font-display text-lg font-extrabold text-brand">C</span>
        </div>
        <span class="font-display text-xl font-bold text-black">Collecta</span>
      </a>
      <div class="hidden items-center gap-8 md:flex">
        <a href="#how-it-works" class="text-sm font-medium text-stone transition-colors hover:text-black">How it works</a>
        <a href="#features" class="text-sm font-medium text-stone transition-colors hover:text-black">Features</a>
        <a href="#pricing" class="text-sm font-medium text-stone transition-colors hover:text-black">Pricing</a>
      </div>
      <a href={REGISTER} class="inline-flex items-center gap-2 rounded-full border border-brand bg-brand px-[18px] py-[9px] text-[13px] font-semibold text-black transition-all hover:bg-brand-deep">Get started →</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero-glow relative overflow-hidden bg-black py-24">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-16">
        <div>
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand/25 bg-brand/10 px-3.5 py-1.5 text-[13px] font-medium text-brand">
            <span class="h-1.5 w-1.5 rounded-full bg-brand"></span> 🇳🇬 Live in Nigeria · 🇰🇪 Kenya coming soon
          </div>
          <h1 class="mb-5 text-[clamp(2.6rem,6vw,4.4rem)] font-extrabold text-white">
            Collect fees.<br /><span class="text-brand">Without the chase.</span>
          </h1>
          <p class="mb-9 max-w-[480px] text-[17px] leading-relaxed text-white/60">
            Collecta helps estates, chamas, suppliers, and community groups collect fees — without awkward follow-ups, manual chasing, or administrative burnout. Set up in minutes. Portal live within 24 hours.
          </p>
          <a href={REGISTER} class="inline-flex items-center gap-2 rounded-full bg-brand px-[34px] py-4 text-base font-semibold text-black transition-all hover:bg-brand-deep">Get started free →</a>
          <div class="mt-12 flex gap-8 border-t border-white/10 pt-10">
            <div>
              <div class="font-display text-[2rem] font-extrabold leading-none text-brand">&lt;10m</div>
              <div class="mt-1 text-[13px] text-white/45">to first payment link</div>
            </div>
            <div>
              <div class="font-display text-[2rem] font-extrabold leading-none text-brand">0</div>
              <div class="mt-1 text-[13px] text-white/45">awkward follow-ups</div>
            </div>
          </div>
        </div>

        <!-- Dashboard mock -->
        <div>
          <div class="rounded-[20px] border border-white/10 bg-white/[0.04] p-6 backdrop-blur-sm">
            <div class="mb-5 flex items-center justify-between">
              <span class="font-display text-[15px] font-bold text-white">Greenpark Estate</span>
              <span class="rounded-full bg-brand/15 px-2.5 py-1 text-[11px] font-semibold text-brand">● Live</span>
            </div>
            <div class="mb-5 grid grid-cols-2 gap-3">
              <div class="rounded-xl border border-white/10 bg-white/[0.06] p-3.5">
                <div class="mb-1.5 text-[11px] text-white/40">Collected (Oct)</div>
                <div class="font-display text-xl font-bold text-brand">₦2.4M</div>
              </div>
              <div class="rounded-xl border border-white/10 bg-white/[0.06] p-3.5">
                <div class="mb-1.5 text-[11px] text-white/40">Collection rate</div>
                <div class="font-display text-xl font-bold text-white">82%</div>
              </div>
            </div>
            <div class="mb-2.5 text-[12px] font-medium text-white/30">RECENT ACTIVITY</div>
            <div class="flex flex-col gap-2">
              {[
                { name: 'Ahmed Maina · Flat 4B', s: 'Paid', c: 'bg-green-500/15 text-green-400' },
                { name: 'Nneka Dabiri · 20 Makina St', s: 'Paid', c: 'bg-green-500/15 text-green-400' },
                { name: 'Mercy Kariuki · Flat 7A', s: 'Due today', c: 'bg-brand/15 text-brand' },
                { name: 'Olu Tolani · Plot 12', s: 'Overdue', c: 'bg-red-500/15 text-red-400' },
                { name: 'Fatima Bello · Flat 2C', s: 'Paid', c: 'bg-green-500/15 text-green-400' },
              ].map((r) => (
                <div class="flex items-center justify-between rounded-lg bg-white/[0.04] px-3 py-2.5">
                  <span class="text-[13px] text-white/70">{r.name}</span>
                  <span class={`rounded-full px-2.5 py-1 text-[11px] font-semibold ${r.c}`}>{r.s}</span>
                </div>
              ))}
            </div>
            <div class="mt-4 flex items-center justify-between border-t border-white/[0.07] pt-3.5">
              <span class="text-[12px] text-white/35">47 of 52 members paid this month</span>
              <span class="text-[12px] font-semibold text-brand">Send reminder →</span>
            </div>
          </div>
          <div class="mt-6 inline-flex items-center gap-2.5 rounded-[10px] border border-brand/25 bg-brand/10 px-4 py-3.5">
            <span class="text-lg">🔒</span>
            <p class="text-[13px] text-white/65">Set up takes 2 minutes. Portal goes live within 24 hours of verification approval.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROOF STRIP -->
  <div class="border-y border-[#F0E098] bg-brand-pale py-5">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="no-scrollbar flex items-center gap-8 overflow-x-auto whitespace-nowrap">
        {proofItems.map((item, i) => (
          <>
            {i > 0 && <span class="shrink-0 text-ink/30">·</span>}
            <div class="flex shrink-0 items-center gap-2.5 text-sm font-medium text-ink">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand-deep"><polyline points="20 6 9 17 4 12"></polyline></svg>
              {item}
            </div>
          </>
        ))}
      </div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <section class="py-24" id="how-it-works">
    <div class="mx-auto max-w-[1100px] px-6 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-brand-mid px-3 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-brand-deep">How it works</div>
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-bold text-black">Set up once.<br />Collections run themselves.</h2>
      <p class="mx-auto mt-4 max-w-[520px] text-stone">Set up your network and payment portal in minutes. Payments go live once your details are verified — usually within 24 hours.</p>
      <div class="mt-14 grid grid-cols-1 gap-px overflow-hidden rounded-[14px] bg-line sm:grid-cols-2 lg:grid-cols-3">
        {steps.map((step) => (
          <div class="bg-white p-8 text-left transition-colors hover:bg-brand-pale">
            <div class="mb-4 flex h-8 w-8 items-center justify-center rounded-lg bg-brand-mid font-display text-[13px] font-bold text-brand-deep">{step.n}</div>
            <h3 class="mb-2 text-[15px] font-semibold text-black">{step.title}</h3>
            <p class="text-sm leading-relaxed text-stone">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="bg-surface py-24" id="features">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-brand-mid px-3 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-brand-deep">Features</div>
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-bold text-black">Everything you need.<br />Nothing you don't.</h2>
      <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="feature-card relative overflow-hidden rounded-[14px] border-[1.5px] border-line bg-white p-7 transition-all hover:border-brand hover:shadow-[0_8px_40px_rgba(0,0,0,0.12)]">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-[10px] bg-brand-mid text-xl">{f.icon}</div>
            <h3 class="mb-2 text-base font-semibold text-black">{f.title}</h3>
            <p class="text-sm text-stone">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO USES -->
  <section class="py-24" id="who">
    <div class="mx-auto max-w-[1100px] px-6 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-brand-mid px-3 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-brand-deep">Who uses Collecta</div>
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-bold text-black">Built for any group<br />that collects recurring fees.</h2>
      <div class="mt-13 grid grid-cols-1 gap-5 pt-8 text-left sm:grid-cols-2 lg:grid-cols-3">
        {whoUses.map((w) => (
          <div class="rounded-[14px] bg-surface p-7 transition-all hover:-translate-y-1 hover:bg-brand-pale hover:shadow-[0_8px_40px_rgba(0,0,0,0.12)]">
            <div class="mb-3.5 text-[28px]">{w.icon}</div>
            <h3 class="mb-2 text-lg font-semibold text-black">{w.title}</h3>
            <p class="text-sm text-stone">{w.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BUILT ON -->
  <section class="bg-surface py-24">
    <div class="mx-auto max-w-[1100px] px-6 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-brand-mid px-3 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-brand-deep">Built on</div>
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-bold text-black">Infrastructure you can trust.</h2>
      <p class="mx-auto mt-4 max-w-[520px] text-stone">Built on Paystack for payments, Africa's Talking for SMS, and Supabase for data — the same infrastructure trusted by thousands of Nigerian and Kenyan businesses.</p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-12">
        <div><p class="text-[22px] font-extrabold text-black">Paystack</p><p class="text-[13px] text-mist">Payments & settlement</p></div>
        <div><p class="text-[22px] font-extrabold text-black">Africa's Talking</p><p class="text-[13px] text-mist">SMS reminders</p></div>
        <div><p class="text-[22px] font-extrabold text-black">Supabase</p><p class="text-[13px] text-mist">Secure data storage</p></div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="py-24" id="pricing">
    <div class="mx-auto max-w-[1100px] px-6 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-brand-mid px-3 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-brand-deep">Pricing</div>
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-bold text-black">Simple pricing.<br />No surprises.</h2>
      <p class="mx-auto mt-4 max-w-[480px] text-stone">No setup fees. No monthly subscription. No contracts. You pay Collecta only when you collect.</p>

      <div class="mx-auto mt-10 max-w-[480px]">
        <div class="overflow-hidden rounded-[14px] border-[1.5px] border-line text-left">
          <div class="bg-black px-9 py-7 text-center">
            <p class="text-4xl font-extrabold leading-none text-brand">₦200 <span class="text-xl font-semibold">+ 2%</span></p>
            <p class="mt-1.5 text-sm text-white/70">per transaction collected</p>
            <p class="mt-1 text-[13px] font-bold text-brand">capped at ₦3,000</p>
          </div>
          <div class="p-9">
            <ul class="mb-7">
              {pricingFeatures.map((f) => (
                <li class="flex items-start gap-2 border-b border-line py-1.5 text-sm text-stone last:border-0">
                  <span class="font-bold text-brand-deep">✓</span> {f}
                </li>
              ))}
            </ul>
            <a href={REGISTER} class="flex w-full items-center justify-center rounded-full bg-brand px-6 py-3 text-sm font-semibold text-black transition-all hover:bg-brand-deep">Start collecting →</a>
          </div>
        </div>
        <div class="mt-4 flex items-start gap-2.5 rounded-lg border border-line bg-surface px-4 py-3.5 text-left">
          <span class="shrink-0 text-base">📱</span>
          <p class="text-[13px] text-stone">Paystack also charges their own processing fee (~1.5% + ₦100) per transaction — their charge, not ours. SMS credits are earned automatically per payment collected; if they run out, SMS pauses and you are notified. Email reminders continue regardless.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand py-24 text-center">
    <div class="mx-auto max-w-[1100px] px-6">
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-bold text-black">Stop chasing. Start collecting.</h2>
      <p class="mx-auto mb-9 mt-4 max-w-[520px] text-[17px] text-black/55">Set up your network in minutes and let Collecta handle the reminders, penalties, and tracking — so you never send another awkward follow-up.</p>
      <a href={REGISTER} class="inline-flex items-center gap-2 rounded-full bg-black px-[34px] py-4 text-base font-semibold text-white transition-all hover:bg-charcoal">Get started free →</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-charcoal pb-8 pt-16">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="mb-12 grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-12">
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="flex items-center gap-2.5">
            <div class="flex h-9 w-9 items-center justify-center rounded-[9px] bg-black"><span class="font-display text-lg font-extrabold text-brand">C</span></div>
            <span class="font-display text-xl font-bold text-white">Collecta</span>
          </a>
          <p class="mt-3 max-w-[260px] text-sm text-white/40">Collect fees without the chase. Built for African communities, estates, and groups.</p>
        </div>
        <div>
          <h4 class="mb-4 font-display text-[13px] font-bold uppercase tracking-[0.08em] text-white/30">Product</h4>
          <ul class="space-y-2.5">
            <li><a href="#how-it-works" class="text-sm text-white/55 transition-colors hover:text-brand">How it works</a></li>
            <li><a href="#features" class="text-sm text-white/55 transition-colors hover:text-brand">Features</a></li>
            <li><a href="#pricing" class="text-sm text-white/55 transition-colors hover:text-brand">Pricing</a></li>
          </ul>
        </div>
        <div>
          <h4 class="mb-4 font-display text-[13px] font-bold uppercase tracking-[0.08em] text-white/30">Company</h4>
          <ul class="space-y-2.5">
            <li><a href={REGISTER} class="text-sm text-white/55 transition-colors hover:text-brand">Get started</a></li>
            <li><a href={`${APP_URL}/login`} class="text-sm text-white/55 transition-colors hover:text-brand">Sign in</a></li>
          </ul>
        </div>
        <div>
          <h4 class="mb-4 font-display text-[13px] font-bold uppercase tracking-[0.08em] text-white/30">Legal</h4>
          <ul class="space-y-2.5">
            <li><a href={`${APP_URL}/terms`} class="text-sm text-white/55 transition-colors hover:text-brand">Terms</a></li>
            <li><a href={`${APP_URL}/privacy`} class="text-sm text-white/55 transition-colors hover:text-brand">Privacy</a></li>
          </ul>
        </div>
      </div>
      <div class="flex flex-wrap items-center justify-between gap-3 border-t border-white/[0.06] pt-7">
        <p class="text-[13px] text-white/30">© 2026 Collecta. All rights reserved.</p>
        <p class="text-[13px] text-white/30">🇳🇬 Nigeria · 🇰🇪 Kenya</p>
      </div>
    </div>
  </footer>
</Layout>
