generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  password                String?
  firstName               String
  lastName                String
  role                    UserRole                 @default(NETWORK_ADMIN)
  isPlatformAdmin         Boolean                  @default(false)
  isEmailVerified         Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  emailVerificationTokens EmailVerificationToken[]
  network                 Network?
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique @default(uuid())
  type      String
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Network {
  id                     String             @id @default(uuid())
  name                   String
  slug                   String             @unique
  description            String?
  logoUrl                String?
  adminId                String             @unique
  networkType            NetworkType        @default(ESTATE)
  verificationStatus     VerificationStatus @default(PENDING)
  isVerified             Boolean            @default(false)
  verificationNotes      String?
  smsCredits             Int                @default(0)
  smsWarningLastSentAt   DateTime?
  brandColor             String?            @default("#F5C842")
  contactPhone           String?
  paystackSubaccountCode String?
  paystackSubaccountId   String?
  bankAccountNumber      String?
  bankAccountName        String?
  bankCode               String?
  settlementBank         String?
  currency               String             @default("NGN")
  country                String             @default("NG")
  timezone               String             @default("Africa/Lagos")
  isActive               Boolean            @default(true)
  referralSource         String?
  lastRunAt              DateTime?
  lastProcessedId        String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  auditLogs              AuditLog[]
  charges                Charge[]
  fees                   Fee[]
  members                Member[]
  admin                  User               @relation(fields: [adminId], references: [id])
  payments               Payment[]
  reminders              Reminder[]
  reminderLogs           ReminderLog[]
  reminderRules          ReminderRule[]
  verificationRequest    VerificationRequest?
  importJobs             ImportJob[]
}

model VerificationRequest {
  id              String             @id @default(uuid())
  networkId       String             @unique
  organisationName String
  cacNumber       String?
  bvn             String?
  nin             String?
  contactAddress  String?
  status          VerificationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  network         Network            @relation(fields: [networkId], references: [id], onDelete: Cascade)
}

model Member {
  id                    String          @id @default(uuid())
  networkId             String
  firstName             String
  lastName              String
  email                 String?
  phone                 String?
  memberCode            String?
  unit                  String?
  notes                 String?
  status                MemberStatus    @default(ACTIVE)
  isGuest               Boolean         @default(false)
  isBlacklisted         Boolean         @default(false)
  blacklistReason       String?
  consecutiveMonthsPaid Int             @default(0)
  smsOptedOut           Boolean         @default(false)
  smsOptedOutAt         DateTime?
  whatsappOptedIn       Boolean         @default(false)
  whatsappOptedInAt     DateTime?
  whatsappOptedOutAt    DateTime?
  inviteToken           String?         @unique
  otpHash               String?
  otpExpiresAt          DateTime?
  joinedAt              DateTime        @default(now())
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  charges               Charge[]
  assignments           FeeAssignment[]
  network               Network         @relation(fields: [networkId], references: [id], onDelete: Cascade)
  payments              Payment[]
  reminders             Reminder[]
  reminderLogs          ReminderLog[]

  @@unique([networkId, email])
}

model Fee {
  id               String         @id @default(uuid())
  networkId        String
  name             String
  description      String?
  type             FeeType
  paymentType      FeePaymentType @default(SCHEDULED)
  amount           Decimal        @default(0) @db.Decimal(12, 2)
  frequency        FeeFrequency   @default(MONTHLY)
  dueDay           Int            @default(1)
  startDate        DateTime?
  windowStart      DateTime?
  windowEnd        DateTime?
  penaltyEnabled   Boolean        @default(false)
  penaltyPercent   Decimal        @default(0) @db.Decimal(5, 2)
  penaltyGraceDays Int            @default(7)
  options          Json?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  charges          Charge[]
  network          Network        @relation(fields: [networkId], references: [id], onDelete: Cascade)
  assignments      FeeAssignment[]
}

model FeeAssignment {
  id           String        @id @default(uuid())
  feeId        String
  memberId     String
  amount       Decimal?      @db.Decimal(12, 2)
  startDate    DateTime      @default(now())
  endDate      DateTime?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  charges      Charge[]
  reminderLogs ReminderLog[]
  fee          Fee           @relation(fields: [feeId], references: [id], onDelete: Cascade)
  member       Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([feeId, memberId])
}

model Charge {
  id                  String         @id @default(uuid())
  networkId           String
  memberId            String
  feeId               String?
  assignmentId        String?
  amount              Decimal        @db.Decimal(12, 2)
  serviceCharge       Decimal        @default(0) @db.Decimal(12, 2)
  paidAmount          Decimal        @default(0) @db.Decimal(12, 2)
  billingMonth        String?
  dueDate             DateTime
  status              ChargeStatus   @default(PENDING)
  penaltyApplied      Boolean        @default(false)
  penaltyAmount       Decimal        @default(0) @db.Decimal(12, 2)
  paystackPaymentLink String?
  paystackReference   String?
  description         String?
  paidAt              DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  assignment          FeeAssignment? @relation(fields: [assignmentId], references: [id])
  fee                 Fee?           @relation(fields: [feeId], references: [id])
  member              Member         @relation(fields: [memberId], references: [id])
  network             Network        @relation(fields: [networkId], references: [id], onDelete: Cascade)
  payments            Payment[]
  reminders           Reminder[]
}

model Payment {
  id                String        @id @default(uuid())
  networkId         String
  chargeId          String
  memberId          String
  amount            Decimal       @db.Decimal(12, 2)
  serviceCharge     Decimal       @default(0) @db.Decimal(12, 2)
  method            PaymentMethod @default(PAYSTACK)
  paystackReference String?       @unique
  metadata          Json?
  recordedById      String?
  createdAt         DateTime      @default(now())
  charge            Charge        @relation(fields: [chargeId], references: [id])
  member            Member        @relation(fields: [memberId], references: [id])
  network           Network       @relation(fields: [networkId], references: [id])
}

model Reminder {
  id                String                  @id @default(uuid())
  networkId         String
  memberId          String
  chargeId          String?
  channel           ReminderChannel
  status            ReminderStatus          @default(PENDING)
  message           String?
  sentAt            DateTime?
  providerMessageId String?
  whatsappStatus    WhatsappDeliveryStatus?
  whatsappStatusAt  DateTime?
  createdAt         DateTime                @default(now())
  charge            Charge?                 @relation(fields: [chargeId], references: [id])
  member            Member                  @relation(fields: [memberId], references: [id])
  network           Network                 @relation(fields: [networkId], references: [id])

  @@index([providerMessageId])
}

model ReminderLog {
  id                String                  @id @default(uuid())
  networkId         String
  memberId          String
  assignmentId      String?
  chargeId          String?
  channel           ReminderChannel
  tone              ReminderTone
  sentDate          String
  providerMessageId String?
  whatsappStatus    WhatsappDeliveryStatus?
  whatsappStatusAt  DateTime?
  createdAt         DateTime                @default(now())
  network           Network                 @relation(fields: [networkId], references: [id], onDelete: Cascade)
  member            Member                  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  assignment        FeeAssignment?          @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@unique([assignmentId, sentDate, channel])
  @@index([providerMessageId])
}

model WhatsappStatusEvent {
  id                String                 @id @default(uuid())
  providerMessageId String
  status            WhatsappDeliveryStatus
  recipientPhone    String?
  errorCode         Int?
  errorTitle        String?
  timestamp         DateTime
  rawPayload        Json
  createdAt         DateTime               @default(now())

  @@unique([providerMessageId, status])
}

model ImportJob {
  id            String          @id @default(uuid())
  networkId     String
  status        ImportJobStatus @default(QUEUED)
  rawData       Json?
  errors        Json            @default("[]")
  totalRows     Int             @default(0)
  processedRows Int             @default(0)
  createdCount  Int             @default(0)
  skippedCount  Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  network       Network         @relation(fields: [networkId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  networkId  String
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  network    Network  @relation(fields: [networkId], references: [id])
}

model ReminderRule {
  id         String   @id @default(uuid())
  networkId  String
  daysOffset Int
  channels   String[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  network    Network  @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@unique([networkId, daysOffset])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  NETWORK_ADMIN
}

enum NetworkType {
  ESTATE
  CHAMA
  SUPPLIER
  DEBT
  GYM
  COMMUNITY
  SCHOOL
  CHURCH
  SPORTS
  COOPERATIVE
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum FeeType {
  ASSIGNED
  OPEN
}

enum FeePaymentType {
  SCHEDULED
  OPEN
  WINDOWED
}

enum FeeFrequency {
  ONE_TIME
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  PARTIALLY_PAID
  WAIVED
  CANCELLED
}

enum PaymentMethod {
  PAYSTACK
  CASH
  BANK_TRANSFER
  OTHER
}

enum ReminderChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ReminderTone {
  FRIENDLY
  CLEAR
  FIRM
  FORMAL
}

enum WhatsappDeliveryStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum ImportJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}
